# Query API data source
# Set TIGER_PRIMARY_URL in deployed preview/production environments.
# DATA_PLANE_SOURCE_URL or DATABASE_URL remain fallback options for local development.
TIGER_PRIMARY_URL=postgres://tsdbadmin:password@your-tiger-host:5432/tsdb?sslmode=require
DATA_PLANE_SOURCE_URL=
DATABASE_URL=

# Query API runtime
QUERY_API_BEARER_TOKEN=replace-with-a-long-random-token
QUERY_API_HOST=0.0.0.0
QUERY_API_PORT=4318

# Data plane tuning
DATA_PLANE_MAX_POOL_SIZE=5
DATA_PLANE_STATEMENT_TIMEOUT_MS=10000

# Optional prior-work archive scanning.
# Leave unset/false in production unless docs/reports is intentionally packaged.
RESEARCH_ARCHIVE_SCAN_FILESYSTEM=false
