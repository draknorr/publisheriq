{
  "name": "@publisheriq/query-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "prebuild": "pnpm --filter @publisheriq/data-plane build",
    "precheck-types": "pnpm --filter @publisheriq/data-plane build",
    "predev": "pnpm --filter @publisheriq/data-plane build",
    "prestart": "pnpm --filter @publisheriq/data-plane build",
    "pretest": "pnpm --filter @publisheriq/data-plane build",
    "build": "tsup src/server.ts --format esm --dts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "node --import tsx --test $(find src -name '*.test.ts' -type f | sort)"
  },
  "dependencies": {
    "@publisheriq/data-plane": "workspace:*",
    "@publisheriq/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.39.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
