# Site URL (required for OTP redirects - must be https://, no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.publisheriq.app
# Optional auth diagnostics (set true temporarily to debug login/session persistence)
NEXT_PUBLIC_AUTH_DEBUG=false

# Dashboard login password
AUTH_PASSWORD=your-password-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# LLM Provider ("openai" or "anthropic")
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Cube.js
USE_CUBE_CHAT=true
CUBE_API_URL=https://your-cube-instance.fly.dev
CUBE_API_SECRET=your-cube-api-secret

# Query API / Tiger chat routing
# Local dev can point at a local query-api on 127.0.0.1:4318.
# Vercel preview/production must set an explicit Railway HTTPS URL.
QUERY_API_BASE_URL=http://127.0.0.1:4318
QUERY_API_BEARER_TOKEN=your-query-api-bearer-token
CHAT_TIGER_PRIMARY_MODE=off
CHAT_TIGER_PRIMARY_TIMEOUT_MS=8000
CHAT_TIGER_SHADOW_MODE=off
CHAT_TIGER_SHADOW_TIMEOUT_MS=8000
CHAT_TIGER_NARRATOR_ENABLED=true
CHAT_TIGER_NARRATOR_TIMEOUT_MS=3000
CHAT_TIGER_LEGACY_FALLBACK_ENABLED=false
CHAT_TIGER_CANARY_USER_IDS=
CHAT_TIGER_YOUTUBE_ENABLED=false
NEXT_PUBLIC_CHAT_TIGER_DEBUG=false

# Local chat eval bypass (localhost-only, requires CHAT_EVAL_SECRET at runtime)
CHAT_EVAL_LOCAL_BYPASS_ENABLED=false
CHAT_EVAL_SECRET=replace-with-long-random-secret
CHAT_EVAL_BYPASS_EMAIL=approved-user@example.com

# Local browser chat bypass (localhost-only, dev mode only)
CHAT_LOCAL_BROWSER_BYPASS_ENABLED=false
CHAT_LOCAL_BROWSER_BYPASS_EMAIL=approved-user@example.com

# Credit system (feature flag)
CREDITS_ENABLED=true
