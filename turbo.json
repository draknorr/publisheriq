{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AUTH_PASSWORD",
        "CHAT_TIGER_CANARY_USER_IDS",
        "CHAT_TIGER_LEGACY_FALLBACK_ENABLED",
        "CHAT_TIGER_NARRATOR_ENABLED",
        "CHAT_TIGER_NARRATOR_TIMEOUT_MS",
        "CHAT_TIGER_PRIMARY_MODE",
        "CHAT_TIGER_PRIMARY_TIMEOUT_MS",
        "CHAT_TIGER_SHADOW_MODE",
        "CHAT_TIGER_SHADOW_TIMEOUT_MS",
        "CHAT_TIGER_YOUTUBE_ENABLED",
        "CHAT_PHASE1_QUALITY_ENABLED",
        "CHANGE_INTEL_READ_STRICT",
        "CHANGE_INTEL_READ_TARGET",
        "CHANGE_INTEL_TIGER_URL",
        "CUBE_API_SECRET",
        "CUBE_API_URL",
        "LLM_PROVIDER",
        "NEXT_PUBLIC_CHAT_TIGER_DEBUG",
        "OPENAI_API_KEY",
        "QDRANT_API_KEY",
        "QDRANT_URL",
        "QUERY_API_BASE_URL",
        "QUERY_API_BEARER_TOKEN",
        "RESEARCH_MCP_BEARER_TOKEN",
        "RESEARCH_MCP_DEFAULT_ROLE",
        "RESEARCH_MCP_HOST",
        "RESEARCH_MCP_PORT",
        "RESEARCH_SQL_SANDBOX_ENABLED",
        "RESEARCH_SQL_MAX_PLAN_COST",
        "SUPABASE_SERVICE_KEY",
        "SUPABASE_URL",
        "TIGER_PRIMARY_URL",
        "USE_CUBE_CHAT"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "steamspy-sync": {
      "dependsOn": ["build"],
      "cache": false
    },
    "applist-sync": {
      "dependsOn": ["build"],
      "cache": false
    },
    "app-change-hints": {
      "dependsOn": ["build"],
      "cache": false
    },
    "change-intel-worker": {
      "dependsOn": ["build"],
      "cache": false
    },
    "storefront-sync": {
      "dependsOn": ["build"],
      "cache": false
    },
    "reviews-sync": {
      "dependsOn": ["build"],
      "cache": false
    },
    "histogram-sync": {
      "dependsOn": ["build"],
      "cache": false
    },
    "scrape-creation-dates": {
      "dependsOn": ["build"],
      "cache": false
    },
    "calculate-trends": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
